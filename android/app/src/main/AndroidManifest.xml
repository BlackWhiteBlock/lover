<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 11+ 包可见性：相册 / 选图 Intent；鸿蒙需声明更多华为相册包 -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PICK" />
            <data android:mimeType="vnd.android.cursor.dir/image" />
        </intent>
        <intent>
            <action android:name="android.intent.action.PICK" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.PICK" />
            <data android:mimeType="video/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.PICK" />
            <data android:mimeType="*/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT" />
            <data android:mimeType="video/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT" />
            <data android:mimeType="*/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.OPEN_DOCUMENT" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.CHOOSER" />
        </intent>
        <package android:name="com.huawei.photos" />
        <package android:name="com.huawei.hmos.photos" />
        <package android:name="com.huawei.gallery" />
        <package android:name="com.ohos.photos" />
        <package android:name="com.hihonor.photos" />
        <package android:name="com.android.gallery3d" />
        <package android:name="com.google.android.apps.photos" />
        <package android:name="com.miui.gallery" />
        <package android:name="com.sec.android.gallery3d" />
        <package android:name="com.coloros.gallery3d" />
        <package android:name="com.vivo.gallery" />
    </queries>

    <application
        android:name=".LoverApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Lover"
        android:usesCleartextTraffic="${usesCleartextTraffic}">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Lover.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 自定义 scheme：H5「打开 Lover」与本地调试 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="lover" android:host="invite" />
            </intent-filter>
            <!-- HTTPS 邀请链接（域名通过 gradle LOVER_INVITE_BASE_URL 配置） -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="${inviteHttpsScheme}"
                    android:host="${inviteHost}"
                    android:pathPrefix="/invite" />
            </intent-filter>
        </activity>
    </application>
</manifest>
