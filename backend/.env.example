NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lover
DATABASE_TIMEOUT_MS=5000

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Development returns SMS_DEV_CODE in the send response.
SMS_PROVIDER=dev
SMS_DEV_CODE=123456
SMS_CODE_TTL_SECONDS=300
SMS_COOLDOWN_SECONDS=60
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# local is development-only. Production requires qiniu and all QINIU_* values.
# 注意：正确变量名是 STORAGE_PROVIDER（不是 STORAGE_DRIVER）。
# 若只写了 STORAGE_DRIVER=qiniu，旧逻辑会忽略并默认 local；现已兼容回退读取 DRIVER。
STORAGE_PROVIDER=local
STORAGE_DIR=./data/uploads
STORAGE_SIGNING_SECRET=dev-storage-secret-change-me
STORAGE_TOKEN_TTL_SECONDS=600
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_UPLOAD_URL=https://upload.qiniup.com
QINIU_DOWNLOAD_DOMAIN=
QINIU_DOWNLOAD_EXPIRES_SECONDS=3600
QINIU_IMAGE_THUMB_FOP=imageMogr2/auto-orient/thumbnail/800x/format/webp/quality/75

PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
TRUST_PROXY=false
