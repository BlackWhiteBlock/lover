NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lover

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Development returns SMS_DEV_CODE in the send response.
SMS_PROVIDER=dev
SMS_DEV_CODE=123456
SMS_CODE_TTL_SECONDS=300
SMS_COOLDOWN_SECONDS=60
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# Local storage is development-only and production startup rejects it.
STORAGE_PROVIDER=local
STORAGE_DIR=./data/uploads
STORAGE_SIGNING_SECRET=dev-storage-secret-change-me
STORAGE_TOKEN_TTL_SECONDS=600

PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
TRUST_PROXY=false
